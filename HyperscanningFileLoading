# Processing steps - LOTS OF EDITING REQUIRED FOR COLUMN 26 DETECTION
def process_all_files(apply_filter=False):
    processed_files = {}
    for csv_file in csv_files:
        file_path = data_path / csv_file
        if file_path.exists():
            print(f"Processing {csv_file}...")
            try:
                # Read with manual column handling for inconsistent column counts
                print(f"  Reading file manually to handle variable column counts...")
                with open(file_path, 'r') as f:
                    lines = f.readlines()
                
                # Parse each line manually to handle variable column counts
                data_rows = []
                max_cols = 0
                cols_25_count = 0
                cols_26_count = 0
                
                for line in lines:
                    if line.strip():
                        cols = line.strip().split(',')
                        if len(cols) == 25:
                            cols_25_count += 1
                        elif len(cols) == 26:
                            cols_26_count += 1
                        max_cols = max(max_cols, len(cols))
                        # Pad with empty strings if needed
                        while len(cols) < 26:
                            cols.append('')
                        data_rows.append(cols[:26])  # Take max 26 columns
                
                print(f"  Rows with 25 columns: {cols_25_count}")
                print(f"  Rows with 26 columns: {cols_26_count}")
                print(f"  Max columns found: {max_cols}")
                
                if max_cols == 25:
                    print(f"  Uh yeah something weird happened again")
                    print(f"  Press Enter to continue anyway...")
                    print(f"  Press 'q' and then Enter to quit the script")
                    user_input = input("Choice: ").lower().strip()
                    if user_input == 'q':
                        print("Exiting script...")
                        exit()
                
                # Create DataFrame with proper column names
                df_filtered = pd.DataFrame(data_rows, columns=col_names_eeg + ['Time', 'Trigger'])
                
                print(f"  Data shape: {df_filtered.shape}")
                print(f"  Assigned columns: {list(df_filtered.columns)}")
                
                # Clean data types - convert numeric columns
                for col in col_names_eeg + ['Time']:
                    df_filtered[col] = pd.to_numeric(df_filtered[col], errors='coerce')
                
                # Show time information
                if 'Time' in df_filtered.columns:
                    time_values = df_filtered['Time'].dropna()
                    if len(time_values) > 0:
                        print(f"  Time range: {time_values.min():.2f} to {time_values.max():.2f}")
                
                # Perform trigger search - this looks for START and STOP instances
                # in the .csv file
                if 'Trigger' in df_filtered.columns:
                    print(f"  Searching entire Trigger column for text-based triggers...")
                    
                    # Remove empty strings and convert to string
                    trigger_column = df_filtered['Trigger'].astype(str)
                    trigger_column = trigger_column[trigger_column != '']
                    
                    start_mask = trigger_column.str.contains('START', case=False, na=False)
                    stop_mask = trigger_column.str.contains('STOP', case=False, na=False)
                    start_triggers = df_filtered[df_filtered['Trigger'].astype(str).str.contains('START', case=False, na=False)]['Trigger']
                    stop_triggers = df_filtered[df_filtered['Trigger'].astype(str).str.contains('STOP', case=False, na=False)]['Trigger']
                    start_indices = start_triggers.index.tolist()
                    stop_indices = stop_triggers.index.tolist()
                    
                    print(f"  START triggers found: {len(start_triggers)}")
                    if len(start_triggers) > 0:
                        print(f"    First START at row: {min(start_indices)} (value: '{start_triggers.iloc[0]}')")
                        print(f"    START values: {start_triggers.unique().tolist()}")
                    
                    print(f"  STOP triggers found: {len(stop_triggers)}")
                    if len(stop_triggers) > 0:
                        print(f"    First STOP at row: {min(stop_indices)} (value: '{stop_triggers.iloc[0]}')")
                        print(f"    STOP values: {stop_triggers.unique().tolist()}")
                    
                    total_triggers = len(start_triggers) + len(stop_triggers)
                    print(f"  Total text-based triggers found: {total_triggers}")
                    
                    if total_triggers == 0:
                        # Check what's actually in the trigger column since there is apparently nothing
                        # This may be an error with how the data is encoded (numeric instead of START/STOP)
                        non_empty_triggers = df_filtered['Trigger'][df_filtered['Trigger'] != '']
                        if len(non_empty_triggers) > 0:
                            print(f"    Found {len(non_empty_triggers)} non-empty trigger values")
                            print(f"    Sample values: {non_empty_triggers.head(10).tolist()}")
                        else:
                            print(f"    Trigger column appears to be empty")
                
                processed_files[csv_file] = df_filtered
                print(f"✓ Processed {csv_file}: {df_filtered.shape[0]} samples, {df_filtered.shape[1]} columns")
            except Exception as e:
                print(f"✗ Error processing {csv_file}: {str(e)}")
        else:
            print(f"✗ File not found: {file_path}")
    return processed_files

